{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals"]
  },
  // `demo` and `e2e` are checked too. They were not, so `pnpm typecheck` reported clean while the code
  // that PROVES the a11y contract (`e2e/demo.spec.ts`) was never type-checked at all — the same shape
  // as `cargo fmt --all` silently skipping the workspace-excluded renderer (#333/#341).
  "include": ["src", "test", "demo", "e2e"]
}
