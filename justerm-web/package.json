{
  "name": "justerm-web",
  "version": "0.7.0",
  "description": "Browser terminal widget for the justerm engine: consumes DecodedFrame, renders via justerm-renderer (WebGL2). Frame-mode now, in-wasm later.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "author": "Ki Hyun Park",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kihyun1998/justerm.git",
    "directory": "justerm-web"
  },
  "homepage": "https://github.com/kihyun1998/justerm/tree/master/justerm-web#readme",
  "bugs": "https://github.com/kihyun1998/justerm/issues",
  "keywords": [
    "terminal",
    "terminal-emulator",
    "xterm",
    "vt100",
    "ansi",
    "webgl",
    "webgl2",
    "wasm",
    "canvas",
    "justerm"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.node.json",
    "build": "tsup",
    "demo": "vite",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "justerm-renderer": "^0.6.0",
    "justerm-wasm-decode": "^0.9.1"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ]
}
