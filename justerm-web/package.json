{
  "name": "justerm-web",
  "version": "0.6.0",
  "description": "Browser terminal widget for the justerm engine: consumes DecodedFrame, renders via beamterm. Frame-mode now, in-wasm later.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": "https://github.com/kihyun1998/justerm",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "demo": "vite"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@beamterm/renderer": "^1.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
