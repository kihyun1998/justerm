# Match at any depth: the workspace shares /target, but the workspace-excluded
# crates (fuzz, justerm-facade) each build their own target/ dir (#100).
target/

# wasm-pack build output (the npm artifact is built in CI / on publish, never committed).
# wasm-pack also writes a nested .gitignore in each, but make it explicit here too.
/justerm-wasm-decode/pkg*

# Local scratch (personal prompt notes — not part of the crate)
/prompt.md

# justerm-web (TS package) — deps + build output, never committed.
/justerm-web/node_modules
/justerm-web/dist
